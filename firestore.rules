rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read their own profile and create it (on sign-up), but never modify it.
    // Preventing writes blocks a child from changing their own role field to 'parent'.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    match /families/{familyId} {

      // Parent creates their own family doc on sign-up (familyId == their uid)
      allow create: if request.auth != null && familyId == request.auth.uid;

      // Any member of the family can read
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == familyId;

      // Only the parent can update or delete the family doc
      allow update, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'parent'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == familyId;

      match /chores/{choreId} {

        // Any family member can read chores
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == familyId;

        // Only parent can add or delete chores
        allow create, delete: if request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'parent'
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == familyId;

        // Parent can update anything; children can only update weeklyCompletions on their own chores
        allow update: if request.auth != null && (
          (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'parent'
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == familyId
          ) || (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'child'
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == familyId
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.kidId == resource.data.kidId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['weeklyCompletions'])
          )
        );
      }
    }
  }
}
